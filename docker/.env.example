XIAOZHI_SERVER_REPO=https://github.com/xiaozhi-labs/xiaozhi-server.git
XIAOZHI_SERVER_REF=main
ENABLE_SHERPA_ONNX=false
COMPOSE_PROJECT_NAME=xiaozhi

# Host ports
MANAGER_BIND=127.0.0.1
MANAGER_PORT=8003
WEBSOCKET_BIND=127.0.0.1
WEBSOCKET_PORT=8007
MQTT_BIND=0.0.0.0
MQTT_PORT=2883
MQTT_TLS_BIND=0.0.0.0
MQTT_TLS_PORT=8883
UDP_BIND=0.0.0.0
UDP_PORT=8990
MYSQL_PORT=3306
REDIS_PORT=6379

# Runtime timezone and service port
TZ=Asia/Bangkok
XIAOZHI_SERVER_PORT=8003

# Database: VM deployment uses local MySQL; Supabase/Postgres is not required.
# Leave XIAOZHI_DATABASE_DSN empty when using docker-compose.vm.mysql.yml so the
# compose overlay can build the DSN from MYSQL_ROOT_PASSWORD and MYSQL_DATABASE.
XIAOZHI_DATABASE_DRIVER=mysql
XIAOZHI_DATABASE_DSN=
WAIT_FOR_DATABASE_HOST=mysql
WAIT_FOR_DATABASE_PORT=3306
MYSQL_ROOT_PASSWORD=change-me
MYSQL_DATABASE=xiaozhi

# Redis used by xiaozhi-server short-term memory/cache.
# On the current VM, docker-compose.vm.mysql.yml joins the existing
# protexa_default network, where mdnac-redis has the alias "redis".
XIAOZHI_REDIS_HOST=redis
XIAOZHI_REDIS_PORT=6379
WAIT_FOR_REDIS_HOST=redis
WAIT_FOR_REDIS_PORT=6379
SHARED_REDIS_NETWORK=protexa_default

# Optional model/provider secrets. Add more XIAOZHI_* overrides here as needed.
OPENAI_API_KEY=
